programa
{
	
	funcao inicio()
	{
		logico igual, diferente, maior, menor, maior_igual, menor_igual
		
		//igual
		igual = 1 == 1
		// diferente
		diferente =  1 != 5
		//maior
		maior = 5 > 2
		//menor
		menor = 2 < 7 
		//maior_igual
		maior_igual = 7 >= 4
		//menor_igual
		menor_igual = 8 <= 8
		
		escreva(menor_igual)
		
	}
}
